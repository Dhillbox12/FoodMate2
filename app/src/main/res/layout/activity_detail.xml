<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical">

    <!-- Scrollable body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Image Area -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="240dp">

                <TextView
                    android:id="@+id/tvDetailEmoji"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/bg_yellow"
                    android:gravity="center"
                    android:text="&#x1F354;"
                    android:textSize="90sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Back Button -->
                <TextView
                    android:id="@+id/btnDetailBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="48dp"
                    android:background="@drawable/bg_back_btn"
                    android:gravity="center"
                    android:text="&#x25C4;"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Fav Button -->
                <TextView
                    android:id="@+id/btnDetailFav"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="48dp"
                    android:background="@drawable/bg_fav_btn"
                    android:gravity="center"
                    android:text="&#x2661;"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Detail Body -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Tags -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvDetailTag1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_tag"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="Terlaris"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailTag2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="Halal"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Food Name -->
                <TextView
                    android:id="@+id/tvDetailName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Burger Crispy Spesial"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <!-- Meta row 1: rating + time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvDetailRatingFull"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:text="&#x2B50; 4.9  (324 ulasan)"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x23F1; 20-30 mnt"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

                <!-- Restaurant -->
                <TextView
                    android:id="@+id/tvDetailRestaurant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F3EA; BurgerMate"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <!-- Price -->
                <TextView
                    android:id="@+id/tvDetailPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 35.000"
                    android:textColor="@color/primary"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deskripsi"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvDetailDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.6"
                    android:text="Deskripsi makanan..."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="20dp" />

                <!-- Quantity -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jumlah"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/btnQtyMinus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_qty_btn"
                        android:gravity="center"
                        android:text="&#x2212;"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQtyNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:minWidth="24dp"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnQtyPlus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_qty_btn"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQtyTotal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="Total: Rp 35.000"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

                <!-- Info Box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_info_yellow"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="&#x26A1; Estimasi tiba: 20-30 menit  &#x1F6F5; Gratis ongkir min. Rp 50K"
                        android:textColor="#A07010"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom CTA Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_white"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/btnDetailFavBottom"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_fav_outline"
            android:gravity="center"
            android:text="&#x2661;"
            android:textColor="@color/primary"
            android:textSize="20sp" />

        <Button
            android:id="@+id/btnAddToCart"
            style="@style/FoodMate.Button.Primary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="&#x1F6D2; Tambah ke Keranjang" />

    </LinearLayout>

</LinearLayout>