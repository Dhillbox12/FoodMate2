<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Application Theme -->
    <style name="Theme.FoodMate" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/text_white</item>
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/status_bar_main</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.FoodMate.Splash" parent="Theme.FoodMate">
        <item name="android:statusBarColor">@color/status_bar_splash</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/primary</item>
    </style>

    <!-- Auth Theme -->
    <style name="Theme.FoodMate.Auth" parent="Theme.FoodMate">
        <item name="android:windowBackground">@color/bg_main</item>
    </style>

    <!-- TextInputLayout Style -->
    <style name="FoodMate.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/bg_white</item>
        <item name="android:paddingTop">0dp</item>
    </style>

    <!-- Primary Button Style -->
    <style name="FoodMate.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Outlined Button Style -->
    <style name="FoodMate.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/border</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Heading Text Style -->
    <style name="FoodMate.Text.Heading" parent="TextAppearance.AppCompat">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Title Text Style -->
    <style name="FoodMate.Text.Title" parent="TextAppearance.AppCompat">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Body Text Style -->
    <style name="FoodMate.Text.Body" parent="TextAppearance.AppCompat">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Caption Text Style -->
    <style name="FoodMate.Text.Caption" parent="TextAppearance.AppCompat">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>

</resources>